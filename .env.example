# Doc Intelligence — Environment Variables
# Copy this file to .env and fill in your values.
# Only one AI provider key is required.

# Anthropic Claude API key (for AI tagging, NL queries, health insights)
# Get yours at: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (alternative AI provider + embeddings)
# Get yours at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Voyage AI API key (Anthropic's embedding partner — alternative to OpenAI for embeddings)
# Get yours at: https://dash.voyageai.com/
# VOYAGE_API_KEY=pa-...
